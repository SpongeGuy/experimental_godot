		{"id":"fd4463dda4ca7367","type":"file","file":"assets/d2d6aa5630828bbc4935fde9fa93aae9.jpg","x":5360,"y":-4960,"width":767,"height":587},
		{"id":"a5dc5677757eb009","type":"file","file":"assets/29bff1d939e9485fb207874872220c14.jpg","x":5093,"y":-4973,"width":267,"height":400},
		{"id":"6d79e29eae00694c","type":"file","file":"assets/b6934303d6afdc73f40005dfc3eb3f48.jpg","x":4807,"y":-4973,"width":286,"height":400},
		{"id":"4241148772273276","type":"file","file":"assets/anthurium/360_F_715645369_b9SuMs21AkVpESRRZSXdcytzZXyrRPVA-731556810.jpg","x":3560,"y":-4865,"width":400,"height":224},
		{"id":"a1e05e5d09d7b030","type":"file","file":"assets/anthurium/Anthurium_at_lalbagh_flower_show_7109-2123049728.jpg","x":3960,"y":-4906,"width":400,"height":267},
		{"id":"c3491ed7ee0fa734","type":"file","file":"assets/anthurium/flowers-blooming-3773978391.jpg","x":3960,"y":-4641,"width":400,"height":225},
		{"id":"f0988178bcdfc77a","type":"file","file":"assets/anthurium/photograph-of-a-big-red-flower-rafflesia-kemumu-on-the-rainforest-floor-m-3551524569.jpg","x":3160,"y":-4773,"width":400,"height":301},
		{"id":"d7d3bca8da656060","type":"file","file":"assets/anthurium/flower-671339605.jpg","x":3560,"y":-4639,"width":400,"height":343},
